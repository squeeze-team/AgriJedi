# Optional weather adapter settings for Open-Meteo using the meteofrance_seamless model
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_CACHE_PATH=.cache/openmeteo
OPEN_METEO_CACHE_TTL_SECONDS=3600

# Optional override if you want to constrain a service-side bbox
# Format: min_lat,min_lon,max_lat,max_lon
# OPEN_METEO_BOUNDING_BOX=-90,-180,90,180

# Backend agent endpoints
YIELD_ANALYSIS_URL=http://localhost:8000/agent/yield-analysis
YIELD_ANALYSIS_LOOKBACK_DAYS=92
MARKET_OVERVIEW_URL=http://localhost:8000/agent/market-overview
MARKET_TIME_RANGE=365

# Optional LLM settings (used by query_analysis_agent and orchestrator_node)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENAI_MODEL=qwen/qwen3.5-flash-02-23
OPENAI_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENAI_TIMEOUT_SECONDS=25
OPENAI_TEMPERATURE=0.2
OPENROUTER_HTTP_REFERER=https://your-app.example
OPENROUTER_X_TITLE=AgriMaster

# Optional bbox half-size in degrees when query provides central lat/lon directly
GEO_FIXED_HALF_SIZE_DEG=0.1

# Optional logger verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
