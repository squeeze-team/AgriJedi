OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_CACHE_PATH=.cache/openmeteo
OPEN_METEO_CACHE_TTL_SECONDS=3600

OPEN_METEO_BOUNDING_BOX=-90,-180,90,180,
YIELD_ANALYSIS_URL=http://localhost:8000/agent/yield-analysis
YIELD_ANALYSIS_LOOKBACK_DAYS=365
MARKET_OVERVIEW_URL=http://localhost:8000/agent/market-overview
MARKET_TIME_RANGE=92

OPENAI_API_KEY=your-api-key
OPENAI_MODEL=openai/gpt-5-mini
OPENAI_API_URL=https://openrouter.ai/api/v1
OPENAI_TIMEOUT_SECONDS=60
OPENAI_TEMPERATURE=1
GEO_FIXED_HALF_SIZE_DEG=0.3
LOG_LEVEL=INFO

REDIS_URL=redis://redis:6379/0
APP_SHOW_USAGE_NOTICE=false
APP_RATE_LIMIT_ENABLED=false
APP_DEVICE_DAILY_LIMIT=10
APP_IP_DAILY_LIMIT=200
APP_SESSION_CHAT_LIMIT=3
APP_SESSION_ANALYSIS_LIMIT=3